# ── Copy this file to secrets.toml and fill in your keys ─────────────────────
# For local dev:  .streamlit/secrets.toml
# For Streamlit Cloud:  paste contents into App Settings → Secrets

# ── LLM provider: "openai" | "groq" | "perplexity" ───────────────────────────
LLM_PROVIDER    = "perplexity"

# Perplexity Sonar (grounded web search built in — no separate news keys needed)
PERPLEXITY_API_KEY = "pplx-..."
OPENAI_MODEL       = "sonar-pro"       # deep dive; "sonar" is the quick pre-screen
# QUICK_MODEL      = "sonar"
# A/B cheaper deep dive: OPENAI_MODEL = "sonar-reasoning-pro"
# PERPLEXITY_SEARCH_DOMAINS = "nseindia.com,bseindia.com,moneycontrol.com,economictimes.indiatimes.com,livemint.com,reuters.com"
# PERPLEXITY_RECENCY = "month"          # month|week|day|hour

# OpenAI / Groq fallbacks (set LLM_PROVIDER accordingly)
# OPENAI_API_KEY  = "sk-proj-..."       # LLM_PROVIDER="openai", OPENAI_MODEL="gpt-4o-mini"
# GROQ_API_KEY    = "gsk_..."           # LLM_PROVIDER="groq",   OPENAI_MODEL="llama-3.3-70b-versatile"

FMP_API_KEY     = "your_fmp_key_here"

FRED_API_KEY    = "your_fred_key_here"

# Optional — only needed if you use the email report feature
SMTP_HOST       = "smtp.gmail.com"
SMTP_PORT       = "587"
SMTP_USER       = "you@gmail.com"
SMTP_PASSWORD   = "xxxx xxxx xxxx xxxx"
FROM_EMAIL      = "you@gmail.com"
TO_EMAILS       = "recipient@gmail.com"

# Optional — comma-separated list of NSE tickers to override the default universe
# e.g. TICKER_UNIVERSE = "RELIANCE.NS,TCS.NS,INFY.NS"
TICKER_UNIVERSE = ""
