# ── Copy this file to secrets.toml and fill in your keys ─────────────────────
# For local dev:  .streamlit/secrets.toml
# For Streamlit Cloud:  paste contents into App Settings → Secrets

OPENAI_API_KEY  = "sk-proj-..."
OPENAI_MODEL    = "gpt-4o-mini"

FMP_API_KEY     = "your_fmp_key_here"

FRED_API_KEY    = "your_fred_key_here"

# Optional — only needed if you use the email report feature
SMTP_HOST       = "smtp.gmail.com"
SMTP_PORT       = "587"
SMTP_USER       = "you@gmail.com"
SMTP_PASSWORD   = "xxxx xxxx xxxx xxxx"
FROM_EMAIL      = "you@gmail.com"
TO_EMAILS       = "recipient@gmail.com"

# Optional — comma-separated list of NSE tickers to override the default universe
# e.g. TICKER_UNIVERSE = "RELIANCE.NS,TCS.NS,INFY.NS"
TICKER_UNIVERSE = ""
